{
  "name": "@clawdstrike/policy",
  "version": "0.1.3",
  "description": "Canonical policy loader and engine (async guards + threat intel)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas/clawdstrike.plugin.schema.json": {
      "default": "./schemas/clawdstrike.plugin.schema.json"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write src/",
    "format:check": "biome check src/"
  },
  "dependencies": {
    "@clawdstrike/adapter-core": "^0.1.1",
    "js-yaml": "^4.1.0",
    "lru-cache": "^11.2.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "license": "Apache-2.0",
  "author": "Clawdstrike Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/backbay-labs/clawdstrike.git",
    "directory": "packages/policy/clawdstrike-policy"
  },
  "homepage": "https://github.com/backbay-labs/clawdstrike",
  "bugs": {
    "url": "https://github.com/backbay-labs/clawdstrike/issues"
  },
  "keywords": [
    "clawdstrike",
    "security",
    "ai-agent",
    "policy"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
