{
  "name": "@clawdstrike/hunt",
  "version": "0.1.0",
  "description": "Hunt query, timeline, and local file loading for Clawdstrike",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "nats": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "nats": {
      "optional": true
    }
  },
  "dependencies": {
    "@clawdstrike/sdk": "^0.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "author": "Clawdstrike Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/backbay-labs/clawdstrike.git",
    "directory": "packages/sdk/clawdstrike-hunt"
  },
  "homepage": "https://github.com/backbay-labs/clawdstrike",
  "bugs": {
    "url": "https://github.com/backbay-labs/clawdstrike/issues"
  },
  "keywords": [
    "clawdstrike",
    "security",
    "hunt",
    "timeline",
    "query"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
