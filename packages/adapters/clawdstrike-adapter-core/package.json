{
  "name": "@clawdstrike/adapter-core",
  "version": "0.1.3",
  "description": "Framework-agnostic adapter interfaces for Clawdstrike",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:cross-adapter": "vitest run --config vitest.cross-adapter.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write src/",
    "format:check": "biome check src/"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "author": "Clawdstrike Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/backbay-labs/clawdstrike.git",
    "directory": "packages/adapters/clawdstrike-adapter-core"
  },
  "homepage": "https://github.com/backbay-labs/clawdstrike",
  "bugs": {
    "url": "https://github.com/backbay-labs/clawdstrike/issues"
  },
  "keywords": [
    "clawdstrike",
    "security",
    "ai-agent",
    "adapter"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
