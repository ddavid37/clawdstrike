{
  "name": "@backbay/cloud-dashboard",
  "version": "0.2.0",
  "private": true,
  "description": "ClawdStrike Cloud web dashboard \u2013 BackbayOS desktop experience",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
