    "react-rnd": "^10.4.13",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "jsdom": "^25.0.0",
